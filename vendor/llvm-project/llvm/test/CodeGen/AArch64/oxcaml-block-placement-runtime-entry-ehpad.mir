# RUN: llc -mtriple=arm64-apple-macosx -run-pass=block-placement -verify-machineinstrs %s -o - | FileCheck %s

--- |
  target datalayout = "e-m:o-i64:64-i128:128-n32:64-S128"
  target triple = "arm64-apple-macosx"

  define oxcaml_nofpcc void @mixed_exceptional_entries() gc "oxcaml" {
  entry:
    ret void

  normal:
    ret void

  lpad:
    ret void

  recover:
    ret void
  }

  !llvm.module.flags = !{!0}
  !0 = !{i32 1, !"oxcaml_module", !"BlockPlacementRuntimeEntryEHPad"}

...
---
name:            mixed_exceptional_entries
alignment:       4
tracksRegLiveness: true
liveins:
  - { reg: '$x26' }
body:             |
  bb.0.entry:
    successors: %bb.1(0x60000000), %bb.2(0x10000000), %bb.3(0x10000000)
    liveins: $x26, $x27, $x28

    B %bb.1

  bb.1.normal:
    liveins: $x26, $x27, $x28

    RET_ReallyLR implicit $x28, implicit $x27

  bb.2.lpad (landing-pad):
    liveins: $x26, $x27, $x28

    RET_ReallyLR implicit $x28, implicit $x27

  bb.3.recover (machine-block-address-taken, runtime-entered):
    liveins: $x0, $x26, $x27, $x28

    RET_ReallyLR implicit $x28, implicit $x27, implicit $x0

...

# CHECK-LABEL: name: mixed_exceptional_entries
# CHECK-DAG: bb.{{[0-9]+}}.lpad (landing-pad):
# CHECK-DAG: bb.{{[0-9]+}}.recover (machine-block-address-taken, runtime-entered):
