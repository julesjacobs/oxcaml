# RUN: llc -mtriple=arm64-apple-macosx -run-pass=prologepilog -o - %s | FileCheck %s

---
name:            ld1_lane_frame_index
tracksRegLiveness: true
stack:
  - { id: 0, type: default, offset: 0, size: 8, alignment: 8,
      stack-id: default, callee-saved-register: '', callee-saved-restored: true }
  - { id: 1, type: default, offset: 0, size: 8, alignment: 8,
      stack-id: default, callee-saved-register: '', callee-saved-restored: true }
body:             |
  bb.0:
    liveins: $lr

    ; CHECK: $d0 = LDRDui $sp
    ; CHECK: $[[BASE:x[0-9]+]] = ADDXri $sp
    ; CHECK: $q0 = LD1i64 killed renamable $q0, 1, killed $[[BASE]]
    renamable $d0 = LDRDui %stack.0, 0, implicit-def $q0 :: (load (s64) from %stack.0)
    renamable $q0 = LD1i64 killed renamable $q0, 1, %stack.1 :: (load (s64) from %stack.1)
    RET_ReallyLR implicit $q0
...
