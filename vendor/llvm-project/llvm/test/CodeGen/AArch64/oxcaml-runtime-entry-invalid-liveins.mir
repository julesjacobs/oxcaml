# RUN: not llc -mtriple=arm64-apple-macosx -run-pass=none -verify-machineinstrs %s -o - 2>&1 | FileCheck %s

--- |
  target datalayout = "e-m:o-i64:64-i128:128-n32:64-S128"
  target triple = "arm64-apple-macosx"

  define oxcaml_nofpcc { i64, i64, i64 } @invalid_runtime_entry_livein(i64 %ds, i64 %alloc, i64 %value) gc "oxcaml" {
  entry:
    ret { i64, i64, i64 } poison
  }

...
---
name:            invalid_runtime_entry_livein
alignment:       4
tracksRegLiveness: true
body:             |
  bb.0.entry (machine-block-address-taken, runtime-entered):
    liveins: $x0, $x1, $x26, $x27, $x28

    RET_ReallyLR implicit $x28, implicit $x27, implicit $x0

...

# CHECK: *** Bad machine code: runtime-entered block has invalid ABI live-in. ***
# CHECK: - p. register: $x1
