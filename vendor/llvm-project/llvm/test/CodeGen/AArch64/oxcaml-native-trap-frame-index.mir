# RUN: llc -mtriple=arm64-apple-macosx -run-pass=prologepilog -verify-machineinstrs %s -o - | FileCheck %s --check-prefix=PEI
# RUN: llc -mtriple=arm64-apple-macosx -start-after=prologepilog -verify-machineinstrs %s -o - | FileCheck %s --check-prefix=ASM

--- |
  target datalayout = "e-m:o-i64:64-i128:128-n32:64-S128"
  target triple = "arm64-apple-macosx"

  define oxcaml_nofpcc void @single_trap_frame_index(i64 %value) gc "oxcaml" {
  entry:
    ret void

  cont:
    ret void

  handler:
    ret void
  }

  define oxcaml_nofpcc void @nested_trap_frame_index(i64 %value) gc "oxcaml" {
  entry:
    ret void

  cont:
    ret void

  outer_handler:
    ret void

  inner_handler:
    ret void
  }

  !llvm.module.flags = !{!0}
  !0 = !{i32 1, !"oxcaml_module", !"NativeTrapFrameIndex"}

...
---
name:            single_trap_frame_index
alignment:       4
tracksRegLiveness: true
liveins:
  - { reg: '$x0' }
  - { reg: '$x26' }
stack:
  - { id: 0, size: 8, alignment: 8 }
body:             |
  bb.0.entry:
    successors: %bb.1(0x80000000)
    liveins: $x0, $x26, $x27, $x28

    OXCAML_PUSH_TRAP %bb.2, implicit-def dead $sp, implicit-def dead $x16, implicit-def $x26, implicit $sp, implicit $x26
    STRXui killed $x0, %stack.0, 0 :: (store (s64) into %stack.0)
    OXCAML_POP_TRAP implicit-def dead $sp, implicit-def $x26, implicit $sp
    B %bb.1

  bb.1.cont:
    liveins: $x26, $x27, $x28

    $x0 = LDRXui %stack.0, 0 :: (load (s64) from %stack.0)
    RET_ReallyLR implicit $x28, implicit $x27, implicit $x0

  bb.2.handler (machine-block-address-taken, runtime-entered):
    liveins: $x0, $x26, $x27, $x28

    RET_ReallyLR implicit $x28, implicit $x27, implicit $x0

...
---
name:            nested_trap_frame_index
alignment:       4
tracksRegLiveness: true
liveins:
  - { reg: '$x0' }
  - { reg: '$x26' }
stack:
  - { id: 0, size: 8, alignment: 8 }
body:             |
  bb.0.entry:
    successors: %bb.1(0x80000000)
    liveins: $x0, $x26, $x27, $x28

    OXCAML_PUSH_TRAP %bb.2, implicit-def dead $sp, implicit-def dead $x16, implicit-def $x26, implicit $sp, implicit $x26
    OXCAML_PUSH_TRAP %bb.3, implicit-def dead $sp, implicit-def dead $x16, implicit-def $x26, implicit $sp, implicit $x26
    STRXui killed $x0, %stack.0, 0 :: (store (s64) into %stack.0)
    OXCAML_POP_TRAP implicit-def dead $sp, implicit-def $x26, implicit $sp
    $x0 = LDRXui %stack.0, 0 :: (load (s64) from %stack.0)
    OXCAML_POP_TRAP implicit-def dead $sp, implicit-def $x26, implicit $sp
    B %bb.1

  bb.1.cont:
    liveins: $x0, $x26, $x27, $x28

    RET_ReallyLR implicit $x28, implicit $x27, implicit $x0

  bb.2.outer_handler (machine-block-address-taken, runtime-entered):
    liveins: $x0, $x26, $x27, $x28

    RET_ReallyLR implicit $x28, implicit $x27, implicit $x0

  bb.3.inner_handler (machine-block-address-taken, runtime-entered):
    liveins: $x0, $x26, $x27, $x28

    RET_ReallyLR implicit $x28, implicit $x27, implicit $x0

...

# PEI-LABEL: name: single_trap_frame_index
# PEI: OXCAML_PUSH_TRAP %bb.2
# PEI-NEXT: STRXui killed $x0, $sp, 3
# PEI: OXCAML_POP_TRAP
# PEI: $x0 = LDRXui $sp, 1

# PEI-LABEL: name: nested_trap_frame_index
# PEI: OXCAML_PUSH_TRAP %bb.2
# PEI-NEXT: OXCAML_PUSH_TRAP %bb.3
# PEI-NEXT: STRXui killed $x0, $sp, 5
# PEI-NEXT: OXCAML_POP_TRAP
# PEI-NEXT: $x0 = LDRXui $sp, 3

# ASM-LABEL: _single_trap_frame_index:
# ASM: adr x16,
# ASM-NEXT: sub sp, sp, #16
# ASM-NEXT: str x26, [sp]
# ASM-NEXT: str x16, [sp, #8]
# ASM-NEXT: mov x26, sp
# ASM: ldr x26, [sp], #16
