# RUN: llc -mtriple=arm64-apple-macosx -run-pass=none -verify-machineinstrs %s -o - | FileCheck %s --check-prefix=MIR
# RUN: llc -mtriple=arm64-apple-macosx -start-after=prologepilog -verify-machineinstrs %s -o - | FileCheck %s --check-prefix=ASM

--- |
  target datalayout = "e-m:o-i64:64-i128:128-n32:64-S128"
  target triple = "arm64-apple-macosx"

  define oxcaml_nofpcc i64 @raise_notrace_edge(i64 %ds, i64 %alloc, i64 %exn) gc "oxcaml" {
  entry:
    ret i64 0

  recover:
    ret i64 1
  }

  !llvm.module.flags = !{!0}
  !0 = !{i32 1, !"oxcaml_module", !"RaiseNotraceEdge"}

...
---
name:            raise_notrace_edge
alignment:       4
tracksRegLiveness: true
liveins:
  - { reg: '$x0' }
frameInfo:
  stackSize:       0
  adjustsStack:    false
body:             |
  bb.0.entry:
    successors: %bb.1(0x80000000)
    liveins: $x0, $x27, $x28

    OXCAML_RAISE_NOTRACE_EDGE $x0, %bb.1, implicit-def dead $x0, implicit-def dead $x16, implicit-def dead $x26, implicit-def dead $sp, implicit $x26, implicit $x27, implicit $x28

  bb.1.recover (machine-block-address-taken, runtime-entered):
    liveins: $x0, $x26, $x27, $x28

    RET_ReallyLR implicit $x28, implicit $x27, implicit $x0

...

# MIR-LABEL: name: raise_notrace_edge
# MIR: bb.0.entry:
# MIR-NEXT: successors: %bb.1
# MIR: OXCAML_RAISE_NOTRACE_EDGE $x0, %bb.1
# MIR: bb.1.recover (machine-block-address-taken, runtime-entered):

# ASM-LABEL: _raise_notrace_edge:
# ASM: mov sp, x26
# ASM-NEXT: ldp x26, x16, [sp], #16
# ASM-NEXT: br x16
