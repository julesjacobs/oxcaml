liveins:
  - { reg: '$x28', virtual-reg: '%121' }
  - { reg: '$x27', virtual-reg: '%122' }
  - { reg: '$x0', virtual-reg: '%123' }
  - { reg: '$x1', virtual-reg: '%124' }
frameInfo:
  isFrameAddressTaken: false
  isReturnAddressTaken: false
  hasStackMap:     false
  hasPatchPoint:   false
  stackSize:       0
  offsetAdjustment: 0
  maxAlignment:    8
  adjustsStack:    true
  hasCalls:        true
  stackProtector:  ''
  functionContext: ''
  maxCallFrameSize: 0
  cvBytesOfCalleeSavedRegisters: 0
  hasOpaqueSPAdjustment: false
  hasVAStart:      false
  hasMustTailInVarArgFunc: false
  hasTailCall:     false
  localFrameSize:  0
  savePoint:       ''
  restorePoint:    ''
fixedStack:      []
stack:
  - { id: 0, name: '', type: default, offset: 0, size: 8, alignment: 8, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 1, name: '', type: default, offset: 0, size: 8, alignment: 8, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 2, name: '', type: default, offset: 0, size: 8, alignment: 8, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 3, name: '', type: default, offset: 0, size: 8, alignment: 8, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 4, name: '', type: default, offset: 0, size: 8, alignment: 8, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
callSites:       []
debugValueSubstitutions: []
constants:       []
machineFunctionInfo: {}
body:             |
  bb.0.L1:
    successors: %bb.1(0x00106035), %bb.2(0x7fef9fcb)
    liveins: $x28, $x27, $x0, $x1
  
    %124:gpr64common = COPY $x1
    %123:gpr64common = COPY $x0
    %122:gpr64 = COPY $x27
    %121:gpr64 = COPY $x28
    ADJCALLSTACKDOWN 0, 0, implicit-def dead $sp, implicit $sp
    %126:gpr64common = LOADgot target-flags(aarch64-got) @"\01_caml_format_int"
    %127:gpr64common = LOADgot target-flags(aarch64-got) @"\01_camlStdlib__immstring191"
    %128:gpr32 = MOVi32imm 1
    %129:gpr64 = SUBREG_TO_REG 0, killed %128, %subreg.sub_32
    $x28 = COPY %121
    $x27 = COPY %122
    $x8 = COPY %126
